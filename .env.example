MONGO_URI=your-mongodb-connection-string
JWT_SECRET=replace-with-a-strong-secret
PORT=5000

# Set the deployed frontend URL here so CORS allows it.
# You can provide one URL in FRONTEND_URL or multiple comma-separated URLs in FRONTEND_URLS.
FRONTEND_URL=https://your-frontend-domain.com
# FRONTEND_URLS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
